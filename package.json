{
  "name": "@renatoadorno/bun-llama-cpp",
  "version": "0.2.0",
  "description": "High-performance FFI bindings from Bun to llama.cpp. Direct dlopen to libllama with zero overhead.",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "native/llama_shims.c",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:shims": "cc -shared -fPIC -o native/libllama_shims.dylib native/llama_shims.c -I llama.cpp/include -I llama.cpp/ggml/include -undefined dynamic_lookup",
    "start": "DYLD_LIBRARY_PATH=llama.cpp/build/bin bun example/demo.ts",
    "start:embed": "DYLD_LIBRARY_PATH=llama.cpp/build/bin bun example/embed.ts",
    "start:parallel": "DYLD_LIBRARY_PATH=llama.cpp/build/bin bun example/parallel.ts",
    "dev": "DYLD_LIBRARY_PATH=llama.cpp/build/bin bun --hot example/demo.ts",
    "test": "DYLD_LIBRARY_PATH=llama.cpp/build/bin bun test tests/"
  },
  "author": "Renato Adorno <renattoadorno@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/renatoadorno/bun-llama-cpp"
  },
  "homepage": "https://github.com/renatoadorno/bun-llama-cpp#readme",
  "bugs": {
    "url": "https://github.com/renatoadorno/bun-llama-cpp/issues"
  },
  "keywords": [
    "llama",
    "llama.cpp",
    "llm",
    "bun",
    "ffi",
    "inference",
    "metal",
    "apple-silicon",
    "gguf"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "optionalDependencies": {
    "@renatoadorno/bun-llama-cpp-darwin-arm64": "0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "llama_cpp_version": "98ae0a0d3 (build 8574)"
}
